{
  "name": "psyflow-website",
  "version": "0.1.0",
  "private": true,
  "description": "Static website for PsyFlow framework documentation and tutorials.",
  "scripts": {
    "dev": "python ../scripts/build-site-data.py && next dev",
    "build": "python ../scripts/build-site-data.py && next build",
