    "start": "next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "9.0.1",
    "rehype-highlight": "7.0.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.13",
    "@types/node": "20.14.10",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.6",
    "postcss": "8.4.41",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.4"
  }
